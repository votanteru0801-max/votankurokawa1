# ==== 動作モード（credentials未取得でもmockでローカル動作可能） ====
LINE_MODE=mock            # mock | live
GOOGLE_SHEETS_MODE=mock   # mock | live
ANTHROPIC_MODE=mock       # mock | live

# ==== アプリ全般 ====
APP_ENV=local             # local | staging | production
TZ=Asia/Tokyo
LOG_LEVEL=INFO

# ==== 唯一の許可ユーザー（石橋輝一） ====
# LINEユーザーIDの確認方法は docs/line-setup.md を参照
ALLOWED_LINE_USER_ID=U0000000000000000000000000000000

# ==== LINE Messaging API（live時のみ必須） ====
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ==== Anthropic Claude API（live時のみ必須） ====
ANTHROPIC_API_KEY=
# モデル名はコードに固定せず環境変数で指定する
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOOL_RETRIES=2

# ==== Google Sheets（live時のみ必須） ====
GOOGLE_APPLICATION_CREDENTIALS=/secrets/google-service-account.json
HR_SPREADSHEET_ID=14Qz4S4s3CGOrjFsijOvjXy542BkG3DJ3gLYzZFAXWvg

# ==== PostgreSQL ====
DATABASE_URL=postgresql+psycopg://kuroeda:kuroeda@db:5432/kuroeda

# ==== 計算ポリシー既定値（docs/calculation-policy.md参照） ====
CALC_POLICY_VERSION=2026.1
CALC_YEAR_PILLAR_BOUNDARY=risshun
CALC_DAY_BOUNDARY_HOUR=0
CALC_TRUE_SOLAR_TIME_CORRECTION=false

# ==== 取り消し可能期限（分） ====
UNDO_WINDOW_MINUTES=1440
